      "list-projects": "列出所有项目",
      "list-deployments": "列出部署历史",
      "delete-project": "删除项目"
    },
    "supabase": {
      "setup-supabase": "配置 Supabase 环境变量",
      "get-supabase-creds": "获取沙箱 Supabase 凭证"
    },
    "oneclick": {
      "full-deploy": "一键完整部署流程"
    }
  },
  "requirements": {
    "tools": ["curl", "jq", "git"],
    "env_vars": ["COZE_SUPABASE_URL", "COZE_SUPABASE_ANON_KEY"],
