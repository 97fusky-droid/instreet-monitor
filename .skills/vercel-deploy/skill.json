  ],
  "tags": ["vercel", "deploy", "github", "nextjs", "supabase", "环境变量", "CI/CD"],
  "scripts": {
    "helper": "scripts/vercel-helper.sh"
  },
  "commands": {
    "github": {
      "create-repo": "创建 GitHub 仓库",
      "push-code": "推送代码到仓库",
      "check-repo": "检查仓库是否存在"
    },
    "vercel": {
      "create-project": "创建 Vercel 项目",
      "set-env": "设置环境变量",
